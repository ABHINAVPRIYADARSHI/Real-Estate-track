# =============================================================================
# Next.js — Real Estate Staff Work Tracker
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js ───────────────────────────────────────────────────────────────────
.next/
out/

# ── Build output ──────────────────────────────────────────────────────────────
build/
dist/

# ── Environment variables ─────────────────────────────────────────────────────
# Keep .env.example committed; ignore everything else
.env
.env.*
!.env.example

# ── Prisma ────────────────────────────────────────────────────────────────────
# Local SQLite dev databases (not used here, but safe to include)
prisma/*.db
prisma/*.db-journal
# Migration lock file is intentionally committed; ignore nothing else in prisma/

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Cache & temp ──────────────────────────────────────────────────────────────
.cache/
.turbo/
.parcel-cache/
*.tgz

# ── PWA / Service Worker generated files ─────────────────────────────────────
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map

# ── Deployment platforms ──────────────────────────────────────────────────────
.vercel/
.netlify/

# ── IDE / Editors ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── OS files ──────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.Trash-*
